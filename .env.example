# ============================================================
# Buganvilla Tours - Variables de entorno
# Docker Compose arranca sin copiar este archivo: todos los valores de desarrollo tienen defaults.
# Copia este archivo como .env solo para habilitar integraciones externas reales.
# NUNCA subas .env al repositorio.
# ============================================================

# SQL Server
# SQL Server exige minimo 8 caracteres y mezcla de mayusculas, minusculas, numeros y simbolos.
DB_PASSWORD=BuganvillaT0urs!Dev

DB_USERNAME=sa

# JWT compartido entre auth-service, gateway y servicios
JWT_SECRET=reemplaza_con_una_cadena_aleatoria_de_minimo_256_bits
JWT_EXPIRATION=86400000

# Token para endpoints internos entre microservicios
INTERNAL_SERVICE_TOKEN=reemplaza_con_un_token_largo_y_aleatorio

# CORS - lista de origenes permitidos
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:4200,http://localhost:5173

# Logging
SHOW_SQL=false
LOG_LEVEL=INFO

# URLs locales entre servicios (sin Docker)
AUTH_SERVICE_URL=http://localhost:8081
CATALOGO_SERVICE_URL=http://localhost:8082
INVENTARIO_SERVICE_URL=http://localhost:8083
RESERVA_SERVICE_URL=http://localhost:8084
PAGO_SERVICE_URL=http://localhost:8085
NOTIFICACION_SERVICE_URL=http://localhost:8086
REPORTE_SERVICE_URL=http://localhost:8087

# apis.net.pe - consulta DNI/RUC
APIS_NET_TOKEN=sk_xxxxx
APIS_NET_BASE_URL=https://api.decolecta.com/v1

# Mercado Pago
MP_ACCESS_TOKEN=APP_USR-xxxxx
MP_PUBLIC_KEY=APP_USR-xxxxx
MP_BACK_URL_SUCCESS=http://localhost:4200/reservas?payment=success
MP_BACK_URL_FAILURE=http://localhost:4200/reservas?payment=failure
MP_BACK_URL_PENDING=http://localhost:4200/reservas?payment=pending
MP_NOTIFICATION_URL=http://localhost:8080/api/mercadopago/webhook

# WhatsApp Business Cloud API
WHATSAPP_ENABLED=false
WHATSAPP_PROVIDER=mock
WHATSAPP_API_BASE_URL=https://graph.facebook.com
WHATSAPP_API_VERSION=v25.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_DEFAULT_LANGUAGE=es_ES
