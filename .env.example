# ============================================================
# Buganvilla Tours — Variables de entorno
# ============================================================
# Para desarrollo local NO es necesario crear este archivo.
# Docker Compose tiene valores por defecto para todo.
#
# Para producción (Azure):
#   1. Copiar: cp .env.example .env
#   2. Completar los valores marcados con <...>
#   3. NUNCA subir .env al repositorio
# ============================================================

# ── BASE DE DATOS ─────────────────────────────────────────
# SQL Server requiere mínimo 8 chars, mayúsculas, minúsculas, números y símbolos
DB_PASSWORD=<contraseña-fuerte-para-sqlserver>
DB_USERNAME=sa

# ── JWT ───────────────────────────────────────────────────
# Generar con: openssl rand -hex 64
JWT_SECRET=<cadena-aleatoria-de-minimo-64-caracteres>
JWT_EXPIRATION=86400000

# ── TOKEN INTERNO ─────────────────────────────────────────
# Comunicación interna entre microservicios
# Generar con: openssl rand -hex 32
INTERNAL_SERVICE_TOKEN=<token-largo-aleatorio>

# ── DOMINIO PÚBLICO (Azure) ───────────────────────────────
# El subdominio de tu VM en Azure (gratis, asignado con az network public-ip update)
# Ejemplo: buganvillatours.eastus.cloudapp.azure.com
CADDY_DOMAIN=<tu-subdominio>.eastus.cloudapp.azure.com

# ── CORS ──────────────────────────────────────────────────
# Agregar tu dominio de Azure para que el navegador no bloquee las peticiones
CORS_ALLOWED_ORIGINS=https://<tu-subdominio>.eastus.cloudapp.azure.com,http://localhost,http://localhost:80,http://localhost:4200

# ── LOGGING ───────────────────────────────────────────────
# Usar INFO en producción (DEBUG genera GBs de logs y expone datos sensibles)
SHOW_SQL=false
LOG_LEVEL=INFO

# ── MERCADO PAGO (sandbox — solo demostración) ────────────
# Obtener en: https://www.mercadopago.com.pe/developers/es/docs/checkout-pro/landing
# El sandbox simula pagos sin dinero real — ideal para demo
MP_ACCESS_TOKEN=APP_USR-<tu-access-token>
MP_PUBLIC_KEY=APP_USR-<tu-public-key>

# URLs a donde MP redirige al usuario después del pago
# Reemplazar <tu-subdominio> con el valor de CADDY_DOMAIN
MP_BACK_URL_SUCCESS=https://<tu-subdominio>.eastus.cloudapp.azure.com/reservas?payment=success
MP_BACK_URL_FAILURE=https://<tu-subdominio>.eastus.cloudapp.azure.com/reservas?payment=failure
MP_BACK_URL_PENDING=https://<tu-subdominio>.eastus.cloudapp.azure.com/reservas?payment=pending

# URL del webhook donde MP notifica el resultado del pago
MP_NOTIFICATION_URL=https://<tu-subdominio>.eastus.cloudapp.azure.com/api/mercadopago/webhook

# URL del frontend al que el backend redirige tras procesar el pago
APP_FRONTEND_URL=https://<tu-subdominio>.eastus.cloudapp.azure.com

# ── WHATSAPP CLOUD API (modo test) ────────────────────────
# Configurar en: https://developers.facebook.com/apps/
# El modo test envía mensajes solo a números verificados en el panel de Meta
WHATSAPP_ENABLED=true
WHATSAPP_PROVIDER=meta
WHATSAPP_API_BASE_URL=https://graph.facebook.com
WHATSAPP_API_VERSION=v25.0
WHATSAPP_PHONE_NUMBER_ID=<id-del-numero-de-whatsapp>
WHATSAPP_BUSINESS_ACCOUNT_ID=<id-cuenta-de-negocio>
WHATSAPP_ACCESS_TOKEN=<token-de-acceso-whatsapp>
WHATSAPP_VERIFY_TOKEN=<token-para-verificar-webhook-opcional>
WHATSAPP_APP_SECRET=<app-secret-opcional>
WHATSAPP_DEFAULT_LANGUAGE=es_ES

# ── APIS.NET.PE ───────────────────────────────────────────
# Consulta de DNI/RUC — obtener en: https://apis.net.pe/
APIS_NET_TOKEN=<tu-token-de-apis-net>
APIS_NET_BASE_URL=https://api.decolecta.com/v1
