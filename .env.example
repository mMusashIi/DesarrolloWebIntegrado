# ============================================================
# Buganvilla Tours — Variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas .env al repositorio.
# ============================================================

# Base de datos SQL Server
DB_URL=jdbc:sqlserver://localhost:1433;databaseName=BuganvillaTours1;encrypt=true;trustServerCertificate=true;
DB_USERNAME=admin
DB_PASSWORD=tu_contrasena_aqui

# JWT
JWT_SECRET=reemplaza_con_una_cadena_aleatoria_de_minimo_256_bits
JWT_EXPIRATION=86400000

# CORS — lista de origenes permitidos (frontend URLs)
CORS_ALLOWED_ORIGINS=http://localhost:4200,https://tu-dominio.com

# Logging
SHOW_SQL=false
LOG_LEVEL=INFO

# Server
PORT=8080

# apis.net.pe — consulta DNI
APIS_NET_TOKEN=sk_xxxxx

# Mercado Pago
MP_ACCESS_TOKEN=APP_USR-xxxxx
MP_PUBLIC_KEY=APP_USR-xxxxx
MP_BACK_URL_SUCCESS=https://tu-dominio.com/pago-exitoso
MP_BACK_URL_FAILURE=https://tu-dominio.com/pago-fallido
MP_BACK_URL_PENDING=https://tu-dominio.com/pago-pendiente
MP_NOTIFICATION_URL=https://tu-dominio.com/api/mercadopago/webhook

# WhatsApp Business Cloud API (desactivado por defecto)
WHATSAPP_ENABLED=false
WHATSAPP_PROVIDER=mock
WHATSAPP_API_BASE_URL=https://graph.facebook.com
WHATSAPP_API_VERSION=v18.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_DEFAULT_LANGUAGE=es_ES
